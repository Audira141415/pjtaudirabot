# =============================================================================
# PJTAUDI BOT — PRODUCTION ENVIRONMENT
# Server: audira@bot-server (Ubuntu 24.04, Docker 28.2.2)
# Generated: 2026-04-10
#
# BEFORE DEPLOYING:
#   1. Fill every value marked <<<CHANGE>>>
#   2. Generate secure secrets with:
#        openssl rand -hex 32       ← for JWT_SECRET & DB_PASSWORD
#        openssl rand -base64 20    ← for ADMIN_PASSWORD
#   3. Copy file to server:
#        scp .env.production audira@<SERVER_IP>:/opt/pjtaudirabot/.env
#   4. Copy Google credentials:
#        scp google-credentials.json audira@<SERVER_IP>:/opt/pjtaudirabot/google-credentials.json
#
# SECRET HANDLING:
#   - Keep this file free of real secrets (safe to track in git)
#   - Store real secrets only on server in: ~/.config/pjtaudi/secrets.env
#   - Run compose with both files:
#       docker compose --env-file .env.production --env-file ~/.config/pjtaudi/secrets.env ...
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
APP_NAME=PJTAudiBot
APP_VERSION=1.0.0
LOG_LEVEL=info

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
# Replace with your actual server IP or domain (no trailing slash)
SERVER_URL=http://192.168.100.157:4000

# ─── Per-Service Ports ───────────────────────────────────────────────────────
API_PORT=4000
TELEGRAM_PORT=4010
WHATSAPP_PORT=4020
DASHBOARD_PORT=3000
BOT_PORT_RANGE_START=4100
BOT_PORT_RANGE_END=4199

# ─── Database ────────────────────────────────────────────────────────────────
# IMPORTANT: hostname = "db" (Docker service name) when running inside compose
# Use "localhost:5433" only if API is run outside compose (dev-only)
DB_USER=pjtaudi
DB_PASSWORD=<<<SET_IN_SERVER_SECRET_STORE>>>
DB_NAME=pjtaudi
DB_PORT=5433
DATABASE_URL=postgresql://pjtaudi:<<<SET_IN_SERVER_SECRET_STORE>>>@db:5432/pjtaudi
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# ─── Redis ───────────────────────────────────────────────────────────────────
# hostname = "redis" (Docker service name) inside compose
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# ─── WhatsApp (Baileys) ──────────────────────────────────────────────────────
WHATSAPP_ENABLED=true
WHATSAPP_SILENT_MODE=true
# Path inside the container (mapped via named volume)
WHATSAPP_SESSION_DIR=/data/whatsapp-sessions
WHATSAPP_RECONNECT_ATTEMPTS=5
WHATSAPP_RECONNECT_DELAY=5000

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=true
# ⚠  Token saat ini dipakai — ROTATE via @BotFather sebelum go-live resmi
# Go to @BotFather → /mybots → select bot → API Token → Revoke
TELEGRAM_BOT_TOKEN=<<<SET_IN_SERVER_SECRET_STORE>>>
TELEGRAM_WEBHOOK_URL=
TELEGRAM_NOC_CHAT_ID=-5256126186

# ─── AI Service ──────────────────────────────────────────────────────────────
# Keep "mock" unless you have a paid OpenAI key — mock = rule-based extraction
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.7
ANTHROPIC_API_KEY=
OLLAMA_ENDPOINT=

# ─── Memory System ───────────────────────────────────────────────────────────
MEMORY_ENABLED=true
MEMORY_SHORT_TERM_MAX=20
MEMORY_SHORT_TERM_TTL=86400
MEMORY_EXTRACTOR_MODE=rules
MEMORY_SEMANTIC_ENABLED=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_STRATEGY=sliding

# ─── Google Sheets ───────────────────────────────────────────────────────────
GOOGLE_SHEETS_ENABLED=true
# Host path on Linux server; if unset, compose falls back to /dev/null
GOOGLE_SHEETS_CREDENTIALS_HOST_PATH=/home/audira/pjtaudirabot/google-credentials.json
# Linux path inside container (target of credentials volume mount)
GOOGLE_SHEETS_CREDENTIALS=/opt/google-credentials/google-credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=1hx2EIvA-gA-wszX34Ptwb6fwczzJxicmZnQZlSDR07s

# ─── Security ────────────────────────────────────────────────────────────────
# Generated: openssl rand -hex 32
JWT_SECRET=<<<SET_IN_SERVER_SECRET_STORE>>>
JWT_EXPIRY=24h
SESSION_EXPIRY=7d
BCRYPT_ROUNDS=12

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_DIR=./logs
LOG_FILE_MAX_SIZE=10m
LOG_FILES_MAX=14
SENTRY_DSN=

# ─── Dashboard Admin ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generated: openssl rand -base64url 14
ADMIN_PASSWORD=<<<SET_IN_SERVER_SECRET_STORE>>>
