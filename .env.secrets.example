# Untracked secrets file for production host
# Location on server: ~/.config/pjtaudi/secrets.env
# Never commit real values.

# Telegram token must be rotated manually in @BotFather.
TELEGRAM_BOT_TOKEN=<<<NEW_TOKEN_FROM_BOTFATHER>>>

# Generated with: openssl rand -hex 32
JWT_SECRET=<<<GENERATE_HEX_64>>>

# Generated with: openssl rand -base64 24
ADMIN_PASSWORD=<<<GENERATE_BASE64>>>

# Generated with: openssl rand -hex 32
DB_PASSWORD=<<<GENERATE_HEX_64>>>

# Keep DATABASE_URL in secret store for apps that read it directly.
DATABASE_URL=postgresql://pjtaudi:<<<GENERATE_HEX_64>>>@db:5432/pjtaudi
