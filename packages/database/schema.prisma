generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                @id @default(cuid())
  platform              Platform
  platformUserId        String
  phoneNumber           String?
  username              String?
  displayName           String
  profileImage          String?
  role                  UserRole              @default(USER)
  status                UserStatus            @default(ACTIVE)
  settings              Json                  @default("{\"language\": \"en\", \"notifications\": true}")
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  lastActivityAt        DateTime?
  auditLogs             AuditLog[]
  broadcastReceipts     BroadcastReceipt[]
  chatLogs              ChatLog[]
  checklistItems        ChecklistItem[]
  commandExecutions     CommandExecution[]
  conversationSummaries ConversationSummary[]
  incidents             Incident[]
  knowledgeEntries      KnowledgeEntry[]
  maintenanceSchedules  MaintenanceSchedule[]
  embeddings            MemoryEmbedding[]
  moderationLogs        ModerationLog[]
  notes                 Note[]
  reminders             Reminder[]
  savedSearches         SavedSearch[]
  sessions              Session[]
  tasks                 Task[]
  assignedTickets       Ticket[]              @relation("AssignedTickets")
  createdTickets        Ticket[]              @relation("CreatedTickets")
  memories              UserMemory[]

  @@unique([platform, platformUserId])
  @@index([status])
  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  botPlatform  Platform
  sessionToken String   @unique
  metadata     Json     @default("{}")
  expiresAt    DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@index([expiresAt])
}

model Command {
  id              String             @id @default(cuid())
  name            String             @unique
  description     String
  category        String
  handler         String
  requiredRole    UserRole           @default(USER)
  rateLimitConfig Json               @default("{\"perHour\": 300, \"perMinute\": 30}")
  isEnabled       Boolean            @default(true)
  aiPowered       Boolean            @default(false)
  version         Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  executions      CommandExecution[]

  @@index([name])
  @@index([category])
}

model CommandExecution {
  id              String          @id @default(cuid())
  commandId       String
  userId          String
  sessionId       String?
  botPlatform     Platform
  input           String
  output          String?
  executionTimeMs Int             @default(0)
  status          ExecutionStatus @default(PENDING)
  errorMessage    String?
  aiUsed          Boolean         @default(false)
  createdAt       DateTime        @default(now())
  command         Command         @relation(fields: [commandId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([commandId])
  @@index([status])
  @@index([botPlatform])
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  action       String
  resource     String
  resourceId   String?
  changes      Json?       @default("{}")
  ipAddress    String?
  userAgent    String?
  status       AuditStatus @default(SUCCESS)
  errorDetails String?
  createdAt    DateTime    @default(now())
  user         User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model BotConfig {
  id               String           @id @default(cuid())
  platform         Platform         @unique
  isActive         Boolean          @default(true)
  configuration    Json             @default("{}")
  lastConnectedAt  DateTime?
  connectionStatus ConnectionStatus @default(DISCONNECTED)
  version          String           @default("1.0.0")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([platform])
}

model RateLimitSnapshot {
  id           String   @id @default(cuid())
  userId       String
  commandId    String?
  requestCount Int      @default(1)
  windowStart  DateTime
  windowEnd    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([commandId])
  @@index([windowStart])
}

model SavedSearch {
  id        String   @id @default(cuid())
  name      String
  userId    String
  type      String
  query     String
  filters   Json?    @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model UserMemory {
  id               String         @id @default(cuid())
  userId           String
  category         MemoryCategory
  key              String
  value            String
  confidence       Float          @default(0.8)
  source           String?
  lastReferencedAt DateTime?
  expiresAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, key])
  @@index([userId])
  @@index([category])
  @@index([expiresAt])
}

model MemoryEmbedding {
  id         String   @id @default(cuid())
  userId     String
  content    String
  embedding  Bytes
  dimensions Int      @default(1536)
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ConversationSummary {
  id           String   @id @default(cuid())
  userId       String
  platform     Platform
  summary      String
  messageCount Int
  startedAt    DateTime
  endedAt      DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([endedAt])
}

model AnalyticsEvent {
  id        String    @id @default(cuid())
  eventType String
  userId    String?
  platform  Platform?
  metadata  Json      @default("{}")
  value     Float?
  createdAt DateTime  @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([platform])
  @@index([createdAt])
}

model DailyStats {
  id                String    @id @default(cuid())
  date              DateTime  @db.Date
  platform          Platform?
  totalMessages     Int       @default(0)
  totalCommands     Int       @default(0)
  totalAIRequests   Int       @default(0)
  totalErrors       Int       @default(0)
  uniqueUsers       Int       @default(0)
  avgResponseTimeMs Float     @default(0)
  topCommands       Json      @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([date, platform])
  @@index([date])
}

model BroadcastMessage {
  id              String             @id @default(cuid())
  title           String
  content         String
  targetPlatform  Platform?
  targetRole      UserRole?
  status          BroadcastStatus    @default(PENDING)
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int                @default(0)
  successCount    Int                @default(0)
  failureCount    Int                @default(0)
  createdBy       String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  receipts        BroadcastReceipt[]

  @@index([status])
  @@index([scheduledAt])
}

model BroadcastReceipt {
  id           String                 @id @default(cuid())
  broadcastId  String
  userId       String
  status       BroadcastReceiptStatus @default(PENDING)
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime               @default(now())
  broadcast    BroadcastMessage       @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, userId])
  @@index([broadcastId])
  @@index([userId])
}

model WebhookConfig {
  id              String    @id @default(cuid())
  name            String    @unique
  url             String
  secret          String?
  events          Json      @default("[]")
  isActive        Boolean   @default(true)
  failureCount    Int       @default(0)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive])
}

model ModerationRule {
  id        String           @id @default(cuid())
  name      String           @unique
  ruleType  ModerationType
  pattern   String
  action    ModerationAction @default(WARN)
  message   String?
  isActive  Boolean          @default(true)
  priority  Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([ruleType])
  @@index([isActive])
}

model ModerationLog {
  id              String           @id @default(cuid())
  userId          String
  ruleId          String?
  ruleName        String
  ruleType        ModerationType
  action          ModerationAction
  originalMessage String
  platform        Platform
  createdAt       DateTime         @default(now())
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ruleType])
  @@index([createdAt])
}

model FlowDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  steps       Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model FlowSession {
  id          String     @id @default(cuid())
  flowName    String
  userId      String
  platform    Platform
  currentStep Int        @default(0)
  data        Json       @default("{}")
  status      FlowStatus @default(ACTIVE)
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([flowName, userId, platform])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model Task {
  id            String       @id @default(cuid())
  userId        String
  title         String
  description   String?
  status        TaskStatus   @default(PENDING)
  priority      TaskPriority @default(MEDIUM)
  category      String?
  dueDate       DateTime?
  completedAt   DateTime?
  client        String?
  location      String?
  tags          Json         @default("[]")
  sourceMessage String?
  sheetSynced   Boolean      @default(false)
  platform      Platform?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@index([priority])
}

model ChecklistTemplate {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  items       Json
  schedule    String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  instances   ChecklistItem[]

  @@index([name])
  @@index([schedule])
}

model ChecklistItem {
  id            String            @id @default(cuid())
  templateId    String
  userId        String
  title         String
  isCompleted   Boolean           @default(false)
  completedAt   DateTime?
  scheduledDate DateTime          @db.Date
  notes         String?
  sheetSynced   Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  template      ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([templateId])
  @@index([scheduledDate])
  @@index([isCompleted])
}

model Incident {
  id            String           @id @default(cuid())
  userId        String
  title         String
  description   String
  rootCause     String?
  solution      String?
  severity      IncidentSeverity @default(MEDIUM)
  status        IncidentStatus   @default(OPEN)
  service       String?
  tags          Json             @default("[]")
  sourceMessage String?
  resolvedAt    DateTime?
  sheetSynced   Boolean          @default(false)
  platform      Platform?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([severity])
  @@index([service])
  @@index([createdAt])
}

model Reminder {
  id            String    @id @default(cuid())
  userId        String
  message       String
  remindAt      DateTime
  isDelivered   Boolean   @default(false)
  deliveredAt   DateTime?
  recurring     String?
  platform      Platform
  sourceMessage String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([remindAt])
  @@index([isDelivered])
}

model KnowledgeEntry {
  id               String    @id @default(cuid())
  userId           String
  topic            String
  question         String
  answer           String
  tags             Json      @default("[]")
  sourceMessages   Json      @default("[]")
  referenceCount   Int       @default(0)
  lastReferencedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([topic])
  @@index([createdAt])
}

model ServerLog {
  id          String   @id @default(cuid())
  hostname    String
  service     String
  logLevel    String
  message     String
  metadata    Json     @default("{}")
  sheetSynced Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([hostname])
  @@index([service])
  @@index([logLevel])
  @@index([createdAt])
}

model Note {
  id            String    @id @default(cuid())
  userId        String
  content       String
  tags          Json      @default("[]")
  sourceMessage String?
  platform      Platform?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ChatLog {
  id            String        @id @default(cuid())
  userId        String
  message       String
  extractedType ExtractedType
  extractedData Json          @default("{}")
  platform      Platform
  confidence    Float         @default(0)
  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([extractedType])
  @@index([createdAt])
}

model Ticket {
  id                String                @id @default(cuid())
  ticketNumber      String                @unique
  createdById       String
  assignedToId      String?
  title             String
  description       String
  status            TicketStatus          @default(OPEN)
  priority          TicketPriority        @default(MEDIUM)
  category          TicketCategory        @default(INCIDENT)
  customer          String?
  location          String?
  ao                String?
  sid               String?
  service           String?
  vlanId            String?
  vlanType          String?
  vlanName          String?
  hostnameSwitch    String?
  port              String?
  ipAddress         String?
  gateway           String?
  subnet            String?
  mode              String?
  problem           String
  rootCause         String?
  solution          String?
  resolvedAt        DateTime?
  closedAt          DateTime?
  source            Platform?
  groupId           String?
  sourceMessage     String?
  tags              Json                  @default("[]")
  metadata          Json                  @default("{}")
  sheetSynced       Boolean               @default(false)
  telegramNotified  Boolean               @default(false)
  lastSyncError     String?
  syncAttemptCount  Int                   @default(0)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  dataExtractions   DataExtraction[]
  escalations       Escalation[]
  slaTracking       SLATracking?
  assignedTo        User?                 @relation("AssignedTickets", fields: [assignedToId], references: [id])
  createdBy         User                  @relation("CreatedTickets", fields: [createdById], references: [id])
  clusterMaster     TicketCluster[]       @relation("ClusterMaster")
  clusterMembership TicketClusterMember[] @relation("ClusterMembers")
  ticketHistory     TicketHistory[]
  survey            SurveyResponse?

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([customer])
  @@index([location])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([createdById])
}

model SurveyResponse {
  id          String   @id @default(cuid())
  ticketId    String   @unique
  rating      Int
  feedback    String?
  source      String?
  createdAt   DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model TicketHistory {
  id          String   @id @default(cuid())
  ticketId    String
  action      String
  field       String?
  oldValue    String?
  newValue    String?
  changedById String?
  note        String?
  createdAt   DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model SLATracking {
  id                  String    @id @default(cuid())
  ticketId            String    @unique
  responseTargetMin   Int       @default(15)
  resolutionTargetMin Int       @default(240)
  responseDeadline    DateTime
  resolutionDeadline  DateTime
  respondedAt         DateTime?
  resolvedAt          DateTime?
  responseBreached    Boolean   @default(false)
  resolutionBreached  Boolean   @default(false)
  responseWarned      Boolean   @default(false)
  resolutionWarned    Boolean   @default(false)
  responseTimeMin     Float?
  resolutionTimeMin   Float?
  slaLevel            String    @default("L1")
  isPaused            Boolean   @default(false)
  pausedAt            DateTime?
  pausedDurationMin   Float     @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  ticket              Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([responseBreached])
  @@index([resolutionBreached])
  @@index([responseDeadline])
  @@index([resolutionDeadline])
}

model EscalationRule {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  triggerType EscalationTrigger
  condition   Json
  targetLevel EscalationLevel   @default(L2)
  isActive    Boolean           @default(true)
  priority    Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([triggerType])
  @@index([isActive])
}

model Escalation {
  id             String            @id @default(cuid())
  ticketId       String
  fromLevel      EscalationLevel
  toLevel        EscalationLevel
  reason         String
  triggerType    EscalationTrigger
  escalatedById  String?
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  notes          String?
  createdAt      DateTime          @default(now())
  ticket         Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([toLevel])
  @@index([createdAt])
}

model AlertRule {
  id              String    @id @default(cuid())
  name            String    @unique
  description     String?
  alertType       AlertType
  conditions      Json
  actions         Json
  cooldownMin     Int       @default(5)
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  triggerCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  alerts          Alert[]

  @@index([alertType])
  @@index([isActive])
}

model Alert {
  id               String        @id @default(cuid())
  ruleId           String
  title            String
  message          String
  severity         AlertSeverity @default(WARNING)
  status           AlertStatus   @default(ACTIVE)
  acknowledgedAt   DateTime?
  acknowledgedById String?
  metadata         Json          @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  rule             AlertRule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model DataExtraction {
  id             String          @id @default(cuid())
  ticketId       String?
  extractedById  String?
  customer       String?
  location       String?
  ao             String?
  sid            String?
  service        String?
  vlanId         String?
  vlanType       String?
  vlanName       String?
  hostnameSwitch String?
  port           String?
  ipAddress      String?
  gateway        String?
  subnet         String?
  mode           String?
  problem        String?
  notes          String?
  rawMessage     String
  confidence     Float           @default(0)
  isDuplicate    Boolean         @default(false)
  duplicateOfId  String?
  category       TicketCategory?
  priorityScore  Int             @default(0)
  platform       Platform?
  groupId        String?
  sheetSynced    Boolean         @default(false)
  createdAt      DateTime        @default(now())
  ticket         Ticket?         @relation(fields: [ticketId], references: [id])

  @@index([customer])
  @@index([location])
  @@index([createdAt])
  @@index([ticketId])
}

model TicketCluster {
  id                  String                 @id @default(cuid())
  clusterNumber       String                 @unique
  masterTicketId      String
  commonLocation      String?
  commonCustomer      String?
  commonService       String?
  commonProblem       String?
  affectedAssets      Json                   @default("[]")
  status              ClusterStatus          @default(OPEN)
  severity            TicketPriority         @default(MEDIUM)
  impactScore         Float                  @default(0)
  affectedTicketCount Int                    @default(1)
  detectedAt          DateTime               @default(now())
  escalatedAt         DateTime?
  resolvedAt          DateTime?
  closedAt            DateTime?
  cascadeOnResolve    Boolean                @default(true)
  resolutionAlias     String?
  metadata            Json                   @default("{}")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  masterTicket        Ticket                 @relation("ClusterMaster", fields: [masterTicketId], references: [id], onDelete: Cascade)
  history             TicketClusterHistory[]
  members             TicketClusterMember[]

  @@index([status])
  @@index([severity])
  @@index([masterTicketId])
  @@index([detectedAt])
  @@index([createdAt])
}

model TicketClusterMember {
  id              String        @id @default(cuid())
  clusterId       String
  ticketId        String
  similarityScore Float         @default(0)
  matchingFactors Json          @default("[]")
  isResolved      Boolean       @default(false)
  resolvedAt      DateTime?
  position        Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  cluster         TicketCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  ticket          Ticket        @relation("ClusterMembers", fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([clusterId, ticketId])
  @@index([clusterId])
  @@index([ticketId])
}

model TicketClusterHistory {
  id        String        @id @default(cuid())
  clusterId String
  action    String
  details   Json          @default("{}")
  changedBy String?
  note      String?
  createdAt DateTime      @default(now())
  cluster   TicketCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@index([clusterId])
  @@index([createdAt])
}

model NetworkBranch {
  id                String       @id @default(cuid())
  branchId          String       @unique
  name              String
  region            String
  city              String?
  totalDevices      Int          @default(0)
  activeDevices     Int          @default(0)
  uptimePercent     Float        @default(100)
  healthScore       Float        @default(100)
  healthStatus      HealthStatus @default(HEALTHY)
  latencyMs         Float        @default(0)
  jitterMs          Float        @default(0)
  bandwidthIn       Float        @default(0)
  bandwidthOut      Float        @default(0)
  utilization       Float        @default(0)
  criticalIncidents Int          @default(0)
  warningIncidents  Int          @default(0)
  metadata          Json         @default("{}")
  lastUpdatedAt     DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([region])
  @@index([healthStatus])
}

model BulkJob {
  id             String        @id @default(cuid())
  jobType        BulkJobType
  status         BulkJobStatus @default(PENDING)
  totalItems     Int           @default(0)
  processedItems Int           @default(0)
  successCount   Int           @default(0)
  failureCount   Int           @default(0)
  input          Json          @default("{}")
  results        Json          @default("[]")
  errorLog       Json          @default("[]")
  createdById    String
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([jobType])
  @@index([createdById])
  @@index([createdAt])
}

model Backup {
  id          String       @id @default(cuid())
  backupType  BackupType
  fileName    String
  filePath    String
