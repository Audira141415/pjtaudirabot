    "@pjtaudirabot/services": "workspace:*",
    "@prisma/client": "^5.7.0",
    "@whiskeysockets/baileys": "^6.6.1",
    "pino": "^8.17.2",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.6.11"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
