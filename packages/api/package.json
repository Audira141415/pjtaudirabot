{
  "name": "@pjtaudirabot/api",
  "version": "1.0.0",
  "description": "REST API server with Fastify",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^4.25.0",
    "@fastify/cors": "^8.4.2",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/rate-limit": "^8.1.0",
    "@fastify/sensible": "^5.5.0",
    "@fastify/static": "^7.0.1",
    "@prisma/client": "^5.7.0",
    "redis": "^4.6.11",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "bcrypt": "^5.1.1",
    "@pjtaudirabot/core": "workspace:*",
    "@pjtaudirabot/config": "workspace:*",
    "@pjtaudirabot/services": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/bcrypt": "^5.0.2",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  }
}
