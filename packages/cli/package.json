{
  "name": "@pjtaudirabot/cli",
  "version": "1.0.0",
  "description": "CLI tool for managing PjtAudiraBot",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "audirabot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@pjtaudirabot/core": "workspace:*",
    "@pjtaudirabot/config": "workspace:*"
  }
}
