# Application
NODE_ENV=development
APP_NAME=PJTAudiBot
APP_VERSION=1.0.0
LOG_LEVEL=debug

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
SERVER_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ─── Per-Service Ports (WAJIB BEDA, jangan bentrok!) ─────────
API_PORT=4000
TELEGRAM_PORT=4010
WHATSAPP_PORT=4020
DASHBOARD_PORT=3000
BOT_PORT_RANGE_START=4100
BOT_PORT_RANGE_END=4199

# Database (PostgreSQL)
DATABASE_URL=postgresql://pjtaudi:dev_password_change_me@localhost:5432/pjtaudi
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# WhatsApp (Baileys)
WHATSAPP_ENABLED=true
WHATSAPP_SILENT_MODE=false
WHATSAPP_SESSION_DIR=./data/whatsapp-sessions
WHATSAPP_RECONNECT_ATTEMPTS=5
WHATSAPP_RECONNECT_DELAY=5000

# Telegram
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=

# AI Service
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.7
ANTHROPIC_API_KEY=
OLLAMA_ENDPOINT=

# Memory System
MEMORY_ENABLED=true
MEMORY_SHORT_TERM_MAX=20
MEMORY_SHORT_TERM_TTL=86400
MEMORY_EXTRACTOR_MODE=rules
MEMORY_SEMANTIC_ENABLED=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_STRATEGY=sliding

# Security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRY=24h
SESSION_EXPIRY=7d
BCRYPT_ROUNDS=10

# Admin User
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_EMAIL=admin@example.com

# Logging
LOG_DIR=./logs
LOG_FILE_MAX_SIZE=10m
LOG_FILES_MAX=14
SENTRY_DSN=
