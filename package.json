{
  "name": "pjtaudirabot",
  "version": "1.0.0",
  "description": "Production-ready multi-platform bot system (WhatsApp + Telegram)",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm recursive run dev --stream",
    "dev:api": "pnpm -C packages/api dev",
    "dev:whatsapp": "pnpm -C packages/bots/whatsapp dev",
    "dev:telegram": "pnpm -C packages/bots/telegram dev",
    "dev:dashboard": "pnpm -C packages/dashboard dev",
    "build": "pnpm recursive run build",
    "start:api": "pnpm -C packages/api start",
    "start:whatsapp": "pnpm -C packages/bots/whatsapp start",
    "start:telegram": "pnpm -C packages/bots/telegram start",
    "test": "pnpm recursive run test",
    "test:watch": "pnpm recursive run test:watch",
    "test:coverage": "pnpm recursive run test:coverage",
    "lint": "pnpm recursive run lint",
    "lint:fix": "pnpm recursive run lint:fix",
    "format": "pnpm recursive run format",
    "type-check": "pnpm recursive run type-check",
    "db:init": "pnpm -C packages/database prisma migrate dev --name init",
    "db:migrate": "pnpm -C packages/database migrate:dev",
    "db:migrate:prod": "pnpm -C packages/database migrate:deploy",
    "db:reset": "pnpm -C packages/database migrate:reset",
    "db:seed": "pnpm -C packages/database db:seed",
    "db:studio": "pnpm -C packages/database studio",
    "docker:infra": "docker compose -f docker/docker-compose.yml up -d db redis",
    "docker:build": "docker compose -f docker/docker-compose.yml build",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:restart": "docker compose -f docker/docker-compose.yml restart",
    "smoke:tickets-modal": "pnpm -C packages/api exec node scripts/seed-open-ticket-smoke.mjs && node scripts/playwright-tickets-bulk-modal-smoke.mjs",
    "setup": "powershell -ExecutionPolicy Bypass -File setup.ps1 setup"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "playwright": "^1.59.1",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^17.4.0"
  }
}
